# Copy to .env and fill in the keys you actually have.
# Providers with no key set are simply skipped when LLMRouter is built from config.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Default model per provider (used when a Tool/Agent doesn't override it).
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4.1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Sandbox
SANDBOX_DOCKER_IMAGE=simple-agentic-system-sandbox:latest
SANDBOX_MAX_CONCURRENT_CONTAINERS=4
SANDBOX_IDLE_TTL_SECONDS=600

# Observability (optional — only used if LangfuseTracer is wired in; requires the
# 'langfuse' extra: pip install simple-agentic-system[langfuse])
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
